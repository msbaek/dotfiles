{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "MAX_THINKING_TOKENS": "12000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "WebFetch",
      "Bash(npm test:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git config:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(python3 -m markitdown:*)",
      "Bash(markitdown:*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_snapshot",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__read_multiple_files",
      "Bash(vis:*)",
      "Bash(curl:*)"
    ],
    "deny": ["Bash(rm -rf /)"],
    "ask": [],
    "defaultMode": "plan"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -f \"$HOME/dotfiles/bin/claude-sessions\" ] && \"$HOME/dotfiles/bin/claude-sessions\" sync; exit 0'",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -f \"$HOME/.claude/hooks/UserPromptSubmit/append_ultrathink.py\" ] && python3 \"$HOME/.claude/hooks/UserPromptSubmit/append_ultrathink.py\"; exit 0'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -f \"$HOME/.ai-dev-kit/repo/.claude-plugin/check_update.sh\" ] && bash \"$HOME/.ai-dev-kit/repo/.claude-plugin/check_update.sh\"; exit 0'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -f \"$HOME/.claude/bin/skills-log.sh\" ] && \"$HOME/.claude/bin/skills-log.sh\"; exit 0'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/msbaek/dotfiles/bin/claude-statusline-combined",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "jdtls@claude-code-lsps": true,
    "kotlin-lsp@claude-code-lsps": true,
    "omnisharp@claude-code-lsps": true,
    "rust-analyzer@claude-code-lsps": true,
    "vtsls@claude-code-lsps": true,
    "kotlin-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "msbaek-tdd@msbaek-claude-plugins": true,
    "context-engineering-fundamentals@context-engineering-marketplace": true,
    "agent-architecture@context-engineering-marketplace": true,
    "agent-evaluation@context-engineering-marketplace": true,
    "agent-development@context-engineering-marketplace": true,
    "cognitive-architecture@context-engineering-marketplace": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "personal-os-skills": {
      "source": {
        "source": "github",
        "repo": "ArtemXTech/personal-os-skills"
      },
      "autoUpdate": true
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      },
      "autoUpdate": true
    }
  },
  "language": "ko",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "생각하는 중",
      "분석하는 중",
      "코드 읽는 중",
      "파일 탐색 중",
      "작성하는 중",
      "검토하는 중",
      "실행하는 중",
      "검색하는 중",
      "변경 적용 중",
      "테스트 확인 중",
      "구조 파악 중",
      "계획 수립 중",
      "의존성 추적 중",
      "리팩토링 중",
      "디버깅 중",
      "패턴 매칭 중",
      "컨텍스트 수집 중",
      "해결책 모색 중",
      "최적화 중",
      "연결고리 찾는 중"
    ]
  },
  "showClearContextOnPlanAccept": true,
  "effortLevel": "high",
  "advisorModel": "claude-opus-4-7",
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "autoUpdates": true,
  "mcpServers": {
    "playwright": {
      "url": "http://localhost:8931/mcp",
      "args": ["@playwright/mcp@0.0.70"]
    },
    "CodeGraphContext": {
      "command": "/Users/msbaek/.pyenv/shims/cgc",
      "args": ["mcp", "start"],
      "disabled": false
    },
    "databricks": {
      "command": "/Users/msbaek/.ai-dev-kit/.venv/bin/python",
      "args": [
        "/Users/msbaek/.ai-dev-kit/repo/databricks-mcp-server/run_server.py"
      ],
      "env": {
        "DATABRICKS_CONFIG_PROFILE": "DEFAULT"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754086039192
  },
  "additionalDirectories": "/Users/msbaek/DocumentsLocal/msbaek_vault"
}
